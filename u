        function library:get_config()
            local Config = {}
        
            for _, v in flags do
                if library.ignored_config_flags[_] then
                    continue
                elseif type(v) == "table" and v.key ~= nil then
                    Config[_] = {active = v.active, mode = v.mode, key = tostring(v.key)}
                elseif type(v) == "table" and v["Transparency"] ~= nil and typeof(v["Color"]) == "Color3" then
                    Config[_] = {Transparency = v["Transparency"], Color = v["Color"]:ToHex()}
                else
                    Config[_] = v
                end
            end 

            local ok, encoded = pcall(http_service.JSONEncode, http_service, Config)
            return ok and encoded or "{}"
        end

        function library:load_config(config_json) 
            if type(config_json) ~= "string" then
                return false
            end
            local ok, config = pcall(http_service.JSONDecode, http_service, config_json)
            if not ok or type(config) ~= "table" then
                return false
            end
            
            for _, v in next, config do 
                local function_set = library.config_flags[_]
                
                if _ == "config_name_list" then 
                    continue
                end

                if function_set then 
                    pcall(function()
                        if type(v) == "table" and v["Transparency"] ~= nil and type(v["Color"]) == "string" then
                            function_set(hex(v["Color"]), v["Transparency"])
                        elseif type(v) == "table" and v["active"] ~= nil then 
                            function_set(v)
                        else
                            function_set(v)
                        end
                    end)
                end 
            end 
            return true
        end 

