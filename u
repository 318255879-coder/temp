        function library:sanitize_name(value)
            local name = tostring(value or ""):gsub("[^%w _%-]", ""):gsub("^%s+", ""):gsub("%s+$", "")
            return string.sub(name, 1, 64)
        end

        local function safe_read(path)
            if type(isfile) ~= "function" or type(readfile) ~= "function" then
                return nil
            end
            local checked, exists = pcall(isfile, path)
            if not checked or not exists then return nil end
            local ok, content = pcall(readfile, path)
            return ok and content or nil
        end

        local function safe_write(path, content)
            if type(writefile) ~= "function" then
                return false
            end
            return pcall(writefile, path, content)
        end

        local function safe_delete(path)
            if type(isfile) ~= "function" or type(delfile) ~= "function" then
                return false
            end
            local checked, exists = pcall(isfile, path)
            if not checked or not exists then return false end
            return pcall(delfile, path)
        end

        local function list_named_files(directory, extension)
            local results = {}
            if type(listfiles) ~= "function" then
                return results
            end
            local ok, files = pcall(listfiles, directory)
            if not ok or type(files) ~= "table" then
                return results
            end
            local pattern = "([^/\\]+)%." .. extension .. "$"
            for _, file in files do
                local name = tostring(file):match(pattern)
                if name and name ~= "autoload" then
                    insert(results, name)
                end
            end
            table.sort(results)
            return results
        end

