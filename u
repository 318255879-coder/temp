                            option.MouseLeave:Connect(function()
                                library:tween(option, {TextColor3 = cfg.mode == v and rgb(255, 255, 255) or themes.preset.text}, 0.1)
                            end)

                            option.MouseButton1Click:Connect(function()
                                cfg.set(v)

                                cfg.set_visible(false)

                                cfg.open = false
                            end)
                        end
                    --  
                --

                -- Functions 
                    function cfg.modify_mode_color(path) -- ts so frikin tuff 💀
                        for _, v in cfg.hold_instances do 
                            v.TextColor3 = rgb(170, 170, 170)
                        end

                        if cfg.hold_instances[path] then 
                            cfg.hold_instances[path].TextColor3 = rgb(255, 255, 255)
                        end
                    end 

                    function cfg.set_mode(mode) 
                        mode = ({hold = "Hold", toggle = "Toggle", always = "Always"})[string.lower(tostring(mode))] or "Toggle"
                        cfg.mode = mode 

                        if mode == "Always" then
                            cfg.set(true)
                        elseif mode == "Hold" then
                            cfg.set(false)
                        end

                        flags[cfg.flag]["mode"] = mode
                        cfg.modify_mode_color(mode)
                    end 

                    function cfg.set(input)
                        if type(input) == "boolean" then 
                            local __cached = input 

                            if cfg.mode == "Always" then 
                                __cached = true 
                            end 

                            cfg.active = __cached 
                            cfg.callback(__cached)
                        elseif tostring(input):find("Enum") then 
                            input = input.Name == "Escape" and "..." or input

                            cfg.key = input or "..."	

                            cfg.callback(cfg.active or false)
                        elseif find({"Toggle", "Hold", "Always"}, input) then 
                            cfg.set_mode(input)

                            if input == "Always" then 
                                cfg.active = true 
                            end 

                            cfg.callback(cfg.active or false)
                        elseif type(input) == "table" then 
                            input.key = type(input.key) == "string" and input.key ~= "..." and library:convert_enum(input.key) or input.key

                            input.key = input.key == Enum.KeyCode.Escape and "..." or input.key
                            cfg.key = input.key or "..."
                            
                            cfg.mode = input.mode or "Toggle"
                            cfg.set_mode(input.mode)

                            if input.active then
                                cfg.active = input.active
                            end
                        end 

                        flags[cfg.flag] = {
                            mode = cfg.mode,
                            key = cfg.key, 
                            active = cfg.active
                        }

                        local _text = tostring(cfg.key) ~= "Enums" and (keys[cfg.key] or tostring(cfg.key):gsub("Enum.", "")) or nil
                        local __text = _text and (tostring(_text):gsub("KeyCode.", ""):gsub("UserInputType.", ""))
                        
                        text.Text = " ".. __text .." "

                        -- if keybind_list_text then
                        --     keybind_list_text.Text = "[ ".. __text  .." ] ".. cfg.name ..":".. string.lower(cfg.mode) .."";
                        --     keybind_list_text.Visible = cfg.active
                        -- end
                    end

                    function cfg.set_visible(bool)
                        if bool then
                            library:close_current_element(cfg)
                            library.current_element_open = cfg
                        elseif library.current_element_open == cfg then
                            library.current_element_open = nil
                        end
                        accent.Visible = bool
                        if bool then
                            library:raise_popup(accent)
                        end
                        library:follow_popup(cfg, accent, keybind_holder, bool)
                    end
                -- 

                -- Connections
                    keybind_holder.MouseButton1Down:Connect(function()
                        task.wait()
                        text.Text = "..."	

                        if cfg.binding then
                            cfg.binding:Disconnect()
                            cfg.binding = nil
                        end

                        cfg.binding = library:connection(uis.InputBegan, function(keycode, game_event)
                            local selected_key = keycode.UserInputType == Enum.UserInputType.Keyboard and keycode.KeyCode or keycode.UserInputType
                            cfg.set(selected_key)

                            cfg.binding:Disconnect() 
                            cfg.binding = nil
                        end)
                    end)

                    keybind_holder.MouseButton2Down:Connect(function()
                        cfg.open = not cfg.open 

                        cfg.set_visible(cfg.open) 
                    end)

                    library:connection(uis.InputBegan, function(input, game_event) 
                        if not game_event then 
                            local selected_key = input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode or input.UserInputType
                            if selected_key == cfg.key then 
                                if cfg.mode == "Toggle" then 
                                    cfg.active = not cfg.active
                                    cfg.set(cfg.active)
                                elseif cfg.mode == "Hold" then 
                                    cfg.set(true)
                                end
                            end
                        end
                    end)

                    library:connection(uis.InputEnded, function(input, game_event) 
                        if game_event then 
                            return 
                        end 

                        local selected_key = input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode or input.UserInputType

                        if selected_key == cfg.key then
                            if cfg.mode == "Hold" then 
                                cfg.set(false)
                            end
                        end

                    end)
                --

                config_flags[cfg.flag] = cfg.set
                cfg.set({mode = cfg.mode, active = cfg.active, key = cfg.key})

                return setmetatable(cfg, library)
            end

            function library:label(options)
                options = type(options) == "table" and options or {name = tostring(options)}
                local cfg = {
                    name = options.name or options.text or "Label",
                    color = options.color or themes.preset.text,
                }
                local label = library:create("TextLabel", {
                    Parent = self.elements,
                    Size = dim2(1, 0, 0, options.height or 12),
                    AutomaticSize = options.wrap and Enum.AutomaticSize.Y or Enum.AutomaticSize.None,
                    BackgroundTransparency = 1,
                    BorderSizePixel = 0,
                    FontFace = fonts["ProggyClean"],
                    Text = cfg.name,
                    TextColor3 = cfg.color,
                    TextSize = 12,
                    TextWrapped = options.wrap or false,
                    TextXAlignment = options.centered and Enum.TextXAlignment.Center or Enum.TextXAlignment.Left,
                    TextYAlignment = Enum.TextYAlignment.Top,
                })
                cfg.instance = label

                function cfg.set(value)
                    cfg.name = tostring(value)
                    label.Text = cfg.name
                end

                function cfg.set_visible(value)
                    label.Visible = value
                end

                if options.tooltip then
                    library:tooltip(label, options.tooltip)
                end
                return setmetatable(cfg, library)
            end

            function library:separator(options)
                options = type(options) == "table" and options or {name = options}
                options = options or {}
                local holder = library:create("Frame", {
                    Parent = self.elements,
                    Size = dim2(1, 0, 0, options.name and 13 or 3),
                    BackgroundTransparency = 1,
                    BorderSizePixel = 0,
                })
                local line = library:create("Frame", {
                    Parent = holder,
                    AnchorPoint = vec2(0, 0.5),
                    Position = dim2(0, 0, 0.5, 0),
                    Size = dim2(1, 0, 0, 1),
                    BorderSizePixel = 0,
                    BackgroundColor3 = rgb(255, 255, 255),
                })
                line.BackgroundColor3 = themes.preset.accent
                library:apply_theme(line, "accent", "BackgroundColor3")

                if options.name then
                    local caption = library:create("TextLabel", {
                        Parent = holder,
                        Position = dim2(0, 5, 0, 0),
                        Size = dim2(0, 0, 1, 0),
                        AutomaticSize = Enum.AutomaticSize.X,
                        BackgroundColor3 = themes.preset.background,
                        BorderSizePixel = 0,
                        FontFace = fonts["ProggyClean"],
                        Text = " " .. tostring(options.name) .. " ",
                        TextColor3 = themes.preset.muted,
                        TextSize = 12,
                    })
                    library:apply_theme(caption, "muted", "TextColor3")
                end

                return {instance = holder, set_visible = function(value) holder.Visible = value end}
            end

            function library:button(options) 
                local cfg = {
                    name = options.name or "button",
                    callback = options.callback or function() end,
                }
                
                -- Instances 
                    local frame = library:create("TextButton", {
                        AnchorPoint = vec2(1, 0);
                        Text = "";
                        AutoButtonColor = false;
                        Parent = self.elements;
                        Position = dim2(1, 0, 0, 0);
                        BorderColor3 = rgb(0, 0, 0);
                        Size = dim2(1, 0, 0, 16);
                        BorderSizePixel = 0;
                        BackgroundColor3 = themes.preset.outline
                    }); library:apply_theme(frame, "outline", "BackgroundColor3")
                    
                    local frame_inline = library:create("Frame", {
                        Parent = frame;
                        Position = dim2(0, 1, 0, 1);
                        BorderColor3 = rgb(0, 0, 0);
                        Size = dim2(1, -2, 1, -2);
                        BorderSizePixel = 0;
                        BackgroundColor3 = themes.preset.inline
                    }); library:apply_theme(frame_inline, "inline", "BackgroundColor3")
                    
                    local text = library:create("TextLabel", {
                        FontFace = fonts["ProggyClean"];
                        TextColor3 = rgb(255, 255, 255);
                        BorderColor3 = rgb(0, 0, 0);
                        Text = cfg.name;
                        Parent = frame;
                        Size = dim2(1, 0, 1, 0);
                        BackgroundTransparency = 1;
                        Position = dim2(0, 1, 0, 1);
                        BorderSizePixel = 0;
                        AutomaticSize = Enum.AutomaticSize.X;
                        TextSize = 12;
                        BackgroundColor3 = rgb(255, 255, 255)
                    });
                -- 

                -- Connections 
                    library:hover(frame_inline, function()
                        return {BackgroundColor3 = themes.preset.inline}
                    end, function()
                        return {BackgroundColor3 = themes.preset.surface}
                    end)
                    if options.tooltip then
                        library:tooltip(frame, options.tooltip)
                    end
                    frame.MouseButton1Down:Connect(function()
                        library:tween(frame_inline, {BackgroundColor3 = themes.preset.background}, 0.08)
                    end)
                    frame.MouseButton1Click:Connect(function()
                        library:tween(frame_inline, {BackgroundColor3 = themes.preset.surface}, 0.08)
                        cfg.callback()
                    end)
                --

                cfg.instance = frame
                function cfg.set_text(value)
                    cfg.name = tostring(value)
                    text.Text = cfg.name
                end
                function cfg.set_visible(value)
                    frame.Visible = value
                end
                
                return setmetatable(cfg, library)
            end 

            function library:init_config(window) 
                if library.config_initialized then
                    return
                end
                library.config_initialized = true

                local main = window:tab({name = "Settings"})
                local config_section = main:column({}):section({name = "Config manager"})
                local config_textbox
                config_holder = config_section:dropdown({
                    name = "Configs",
                    options = {},
                    placeholder = "Select config",
                    callback = function(option)
                        if config_textbox and option then config_textbox.set(option) end
                    end,
                    flag = "manager_config_list",
                })
                config_textbox = config_section:textbox({name = "Config name", flag = "manager_config_name", placeholder = "example"})
                config_section:button({name = "Save config", callback = function()
                    library:save_config(flags.manager_config_name)
                    library:update_config_list()
                end})
                config_section:button({name = "Load config", callback = function()
                    library:load_config_file(flags.manager_config_name)
                end})
                config_section:button({name = "Delete config", callback = function()
                    library:delete_config(flags.manager_config_name)
                    library:update_config_list()
                end})
                config_section:button({name = "Set config autoload", callback = function()
                    library:set_autoload("config", flags.manager_config_name)
                end})
                config_section:button({name = "Clear config autoload", callback = function()
                    library:clear_autoload("config")
                end})
                config_section:separator({name = "Menu"})
                config_section:keybind({name = "Menu bind", flag = "menu_bind", callback = function(bool) window.toggle_menu(bool) end, default = true})
                config_section:label({name = "fyntra/examplegame/configs", color = themes.preset.muted})

                local theme_section = main:column({}):section({name = "Theme manager"})
                local theme_pickers = {}
                local theme_textbox

                local function sync_theme_pickers()
                    local palette = library:get_theme()
                    for key, picker in theme_pickers do
                        if palette[key] then picker.set(palette[key]) end
                    end
                end

                theme_section:dropdown({
                    name = "Preset",
                    items = {"Fyntra", "Obsidian", "Ember", "Orchid", "Verdant", "Arctic"},
                    default = "Fyntra",
                    flag = "manager_theme_preset",
                    callback = function(name)
                        if library.themes[name] then
                            library:load_theme(name)
                            sync_theme_pickers()
                        end
                    end,
                })

                theme_holder = theme_section:dropdown({
                    name = "Saved themes",
                    options = {},
                    placeholder = "Select theme",
                    flag = "manager_theme_list",
                    callback = function(option)
                        if theme_textbox and option then theme_textbox.set(option) end
                    end,
                })
                theme_textbox = theme_section:textbox({name = "Theme name", flag = "manager_theme_name", placeholder = "custom"})
                theme_section:button({name = "Save theme", callback = function()
                    library:save_theme(flags.manager_theme_name)
                    library:update_theme_list()
                end})
                theme_section:button({name = "Load theme", callback = function()
                    if library:load_theme_file(flags.manager_theme_name) then sync_theme_pickers() end
                end})
                theme_section:button({name = "Delete theme", callback = function()
                    library:delete_theme(flags.manager_theme_name)
                    library:update_theme_list()
                end})
                theme_section:button({name = "Set theme autoload", callback = function()
                    library:set_autoload("theme", flags.manager_theme_name)
                end})
                theme_section:button({name = "Clear theme autoload", callback = function()
                    library:clear_autoload("theme")
                end})

                local function add_theme_color(name, key)
                    theme_pickers[key] = theme_section:colorpicker({
                        name = name,
                        flag = "manager_theme_" .. key,
                        color = themes.preset[key],
                        callback = function(value) library:update_theme(key, value) end,
                    })
                end

                add_theme_color("Accent", "accent")
                add_theme_color("Background", "background")
                add_theme_color("Panel", "panel")
                add_theme_color("Surface", "surface")
                add_theme_color("Inline", "inline")
                add_theme_color("Outline", "outline")
                add_theme_color("Text", "text")
                add_theme_color("Muted text", "muted")
                add_theme_color("Text outline", "text_outline")
                theme_section:label({name = "fyntra/examplegame/theme", color = themes.preset.muted})

                for _, flag in {
                    "manager_config_list", "manager_config_name", "manager_theme_preset", "manager_theme_list", "manager_theme_name",
                    "manager_theme_accent", "manager_theme_background", "manager_theme_panel", "manager_theme_surface",
                    "manager_theme_inline", "manager_theme_outline", "manager_theme_text", "manager_theme_muted", "manager_theme_text_outline",
                } do
                    library.ignored_config_flags[flag] = true
                end

                library:update_config_list()
                library:update_theme_list()
                task.defer(function()
                    library:load_autoloads()
                    sync_theme_pickers()
                end)
            end
        -- 
    -- 
-- 

return library, notifications
