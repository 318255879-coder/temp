        function library:raise_popup(popup, base_zindex)
            base_zindex = base_zindex or 300
            popup.ZIndex = base_zindex
            for _, descendant in popup:GetDescendants() do
                if descendant:IsA("GuiObject") then
                    local original_zindex = descendant:GetAttribute("PopupBaseZIndex")
                    if original_zindex == nil then
                        original_zindex = descendant.ZIndex
                        descendant:SetAttribute("PopupBaseZIndex", original_zindex)
                    end
                    descendant.ZIndex = base_zindex + original_zindex
                end
            end
        end

        function library:position_popup(popup, anchor, gap)
            if not popup or not popup.Parent or not anchor or not anchor.Parent then
                return false
            end

            gap = tonumber(gap) or 2
            local width_mode = popup:GetAttribute("PopupWidthMode")
            local width = if width_mode == "Anchor" then anchor.AbsoluteSize.X
                elseif width_mode == "Fixed" then (popup:GetAttribute("PopupFixedWidth") or popup.AbsoluteSize.X)
                else max(anchor.AbsoluteSize.X, popup.AbsoluteSize.X)
            local viewport_width = camera and camera.ViewportSize.X or width
            local absolute_x = anchor.AbsolutePosition.X + (anchor.AbsoluteSize.X - width) * 0.5
            absolute_x = clamp(absolute_x, 2, max(2, viewport_width - width - 2))
            local absolute_y = anchor.AbsolutePosition.Y + anchor.AbsoluteSize.Y + gap
            local parent_position = popup.Parent:IsA("GuiObject") and popup.Parent.AbsolutePosition or vec2(0, 0)

            popup.AnchorPoint = vec2(0, 0)
            popup.Size = dim2(0, width, popup.Size.Y.Scale, popup.Size.Y.Offset)
            popup.Position = dim_offset(
                floor(absolute_x - parent_position.X + 0.5),
                floor(absolute_y - parent_position.Y + 0.5)
            )
            return true
        end

        function library:follow_popup(cfg, popup, anchor, visible)
            if cfg.popup_connection then
                cfg.popup_connection:Disconnect()
                cfg.popup_connection = nil
            end

            if not visible then
                return
            end

            library:position_popup(popup, anchor)
            cfg.popup_connection = library:connection(run.RenderStepped, function()
                if popup.Visible and popup.Parent and anchor.Parent then
                    library:position_popup(popup, anchor)
                else
                    cfg.open = false
                    cfg.set_visible(false)
                end
            end)
        end

