        function library:get_config()
            local Config = {}
        
            for _, v in flags do
                if type(v) == "table" and v.key then
                    Config[_] = {active = v.active, mode = v.mode, key = tostring(v.key)}
                elseif type(v) == "table" and v["Transparency"] and v["Color"] then
                    Config[_] = {Transparency = v["Transparency"], Color = v["Color"]:ToHex()}
                else
                    Config[_] = v
                end
            end 
            
            return http_service:JSONEncode(Config)
        end

        function library:load_config(config_json) 
            local config = http_service:JSONDecode(config_json)
            
            for _, v in next, config do 
                local function_set = library.config_flags[_]
                
                if _ == "config_name_list" then 
                    continue
                end

                if function_set then 
                    if type(v) == "table" and v["Transparency"] and v["Color"] then
                        function_set(hex(v["Color"]), v["Transparency"])
                    elseif type(v) == "table" and v["active"] then 
                        function_set(v)
                    else
                        function_set(v)
                    end
                end 
            end 
        end 
        
        function library:round(number, float) 
            local multiplier = 1 / (float or 1)

            return floor(number * multiplier + 0.5) / multiplier
        end 

        function library:apply_theme(instance, theme, property) 
            if themes.utility[theme] and themes.utility[theme][property] then
                insert(themes.utility[theme][property], instance)
            end
        end

        function library:update_theme(theme, color)
            if not themes.preset[theme] or not themes.utility[theme] then
                return false
            end

            local targets = theme == "accent" and {"accent", "1", "2", "3"} or {theme}
            for _, target in targets do
                for property_name, objects in themes.utility[target] do
                    for _, object in objects do
                        if object and object.Parent then
                            object[property_name] = color
                        end
                    end
                end
                themes.preset[target] = color
            end

            library:refresh_gradients()
            for _, callback in library.theme_callbacks do
                callback(theme, color)
            end
            return true
        end 

        function library:gradient_sequence(colors)
            colors = colors or {themes.preset["1"], themes.preset["2"], themes.preset["3"]}
            local keypoints = {}
            local denominator = max(#colors - 1, 1)

            for index, value in colors do
                insert(keypoints, rgbkey((index - 1) / denominator, value))
            end

            return rgbseq(keypoints)
        end

        function library:apply_gradient(parent, options)
            options = options or {}
            local gradient = library:create("UIGradient", {
                Parent = parent,
                Color = options.color or library:gradient_sequence(),
                Rotation = options.rotation or 0,
                Transparency = options.transparency or NumberSequence.new(0),
                Offset = options.offset or vec2(0, 0),
            })

            gradient:SetAttribute("LibraryGradient", options.color == nil)
            insert(library.gradients, gradient)
            return gradient
        end

        function library:refresh_gradients()
            local sequence = library:gradient_sequence()
            for index = #library.gradients, 1, -1 do
                local gradient = library.gradients[index]
                if not gradient or not gradient.Parent then
                    remove(library.gradients, index)
                elseif gradient:GetAttribute("LibraryGradient") then
                    gradient.Color = sequence
                end
            end
        end

        function library:set_theme(values)
            for key, value in values do
                if typeof(value) == "Color3" then
                    library:update_theme(tostring(key), value)
                end
            end
            return library:get_theme()
        end

        function library:get_theme()
            return table.clone(themes.preset)
        end

        function library:register_theme(name, values)
            library.themes[name] = table.clone(values)
            return library.themes[name]
        end

        function library:load_theme(theme)
            local values = type(theme) == "string" and library.themes[theme] or theme
            if not values then
                return false
            end
            library:set_theme(values)
            return true
        end

        function library:hover(object, normal_properties, hover_properties)
            object.MouseEnter:Connect(function()
                library:tween(object, type(hover_properties) == "function" and hover_properties() or hover_properties)
            end)
            object.MouseLeave:Connect(function()
                library:tween(object, type(normal_properties) == "function" and normal_properties() or normal_properties)
            end)
        end

        function library:raise_popup(popup, base_zindex)
            base_zindex = base_zindex or 300
            popup.ZIndex = base_zindex
            for _, descendant in popup:GetDescendants() do
                if descendant:IsA("GuiObject") then
                    local original_zindex = descendant:GetAttribute("PopupBaseZIndex")
                    if original_zindex == nil then
                        original_zindex = descendant.ZIndex
                        descendant:SetAttribute("PopupBaseZIndex", original_zindex)
                    end
                    descendant.ZIndex = base_zindex + original_zindex
                end
            end
        end

        function library:position_popup(popup, anchor, gap)
            gap = gap or 0
            local width = max(anchor.AbsoluteSize.X, popup.AbsoluteSize.X)
            local x = anchor.AbsolutePosition.X + (anchor.AbsoluteSize.X - width) * 0.5

            popup.Size = dim2(0, width, popup.Size.Y.Scale, popup.Size.Y.Offset)
            popup.Position = dim_offset(
                floor(x + 0.5),
                floor(anchor.AbsolutePosition.Y + anchor.AbsoluteSize.Y + gap + 0.5)
            )
        end

        function library:tooltip(object, text)
            local holder = library:create("Frame", {
                Parent = library.gui,
                Visible = false,
                AutomaticSize = Enum.AutomaticSize.XY,
                BorderSizePixel = 0,
                BackgroundColor3 = themes.preset.outline,
