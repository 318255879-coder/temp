        function library:save_theme(name)
            name = library:sanitize_name(name)
            if name == "" then return false end
            local data = {}
            for _, key in {"accent", "outline", "inline", "panel", "background", "surface", "text", "muted", "text_outline"} do
                local value = themes.preset[key]
                if typeof(value) == "Color3" then
                    data[key] = value:ToHex()
                end
            end
            local ok, encoded = pcall(http_service.JSONEncode, http_service, data)
            return ok and safe_write(theme_directory .. "/" .. name .. ".json", encoded)
        end

        function library:load_theme_file(name)
            name = library:sanitize_name(name)
            local content = name ~= "" and safe_read(theme_directory .. "/" .. name .. ".json")
            if not content then return false end
            local ok, decoded = pcall(http_service.JSONDecode, http_service, content)
            if not ok or type(decoded) ~= "table" then return false end
            local palette = {}
            for key, value in decoded do
                if themes.utility[key] and type(value) == "string" then
                    local color_ok, parsed = pcall(hex, value)
                    if color_ok then palette[key] = parsed end
                end
            end
            return library:load_theme(palette)
        end

        function library:delete_theme(name)
            name = library:sanitize_name(name)
            return name ~= "" and safe_delete(theme_directory .. "/" .. name .. ".json")
        end

        function library:set_autoload(kind, name)
            name = library:sanitize_name(name)
            if name == "" then return false end
            local path = kind == "theme" and theme_autoload_path or config_autoload_path
            return safe_write(path, name)
        end

        function library:clear_autoload(kind)
