        function notifications:fade(path, is_fading)
            local fading = is_fading and 1 or 0 

            local path_original = path:GetAttribute("OriginalBackgroundTransparency")
            if path_original == nil then
                path_original = path.BackgroundTransparency
                path:SetAttribute("OriginalBackgroundTransparency", path_original)
            end
            library:tween(path, {BackgroundTransparency = is_fading and 1 or path_original}, 0.35, Enum.EasingStyle.Exponential)
        
            for _, instance in path:GetDescendants() do 
                if not instance:IsA("GuiObject") then 
                    if instance:IsA("UIStroke") then
                        library:tween(instance, {Transparency = fading}, 0.35, Enum.EasingStyle.Exponential)
                    end
        
                    continue
                end 
        
                if instance:IsA("TextLabel") then
                    library:tween(instance, {TextTransparency = fading}, 0.35, Enum.EasingStyle.Exponential)
                elseif instance:IsA("Frame") then
                    local original = instance:GetAttribute("OriginalBackgroundTransparency")
                    if original == nil then
                        original = instance.BackgroundTransparency
                        instance:SetAttribute("OriginalBackgroundTransparency", original)
                    end
                    library:tween(instance, {BackgroundTransparency = is_fading and 1 or original}, 0.35, Enum.EasingStyle.Exponential)
                end
            end
        end 
        
