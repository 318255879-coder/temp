        function notifications:refresh_notifs(instant) 
            local viewport = camera and camera.ViewportSize or vec2(1920, 1080)
            local corner = notifications.position.corner
            local right = string.find(corner, "Right", 1, true) ~= nil
            local bottom = string.find(corner, "Bottom", 1, true) ~= nil
            local x = right and (viewport.X - notifications.position.x) or notifications.position.x
            local base_y = bottom and (viewport.Y - notifications.position.y) or notifications.position.y

            for i, v in notifications.notifs do 
                v.AnchorPoint = vec2(right and 1 or 0, bottom and 1 or 0)
                local y = base_y + ((bottom and -1 or 1) * (i - 1) * 28)
                local target = dim_offset(x, y)
                if instant then
                    v.Position = target
                else
                    tween_service:Create(v, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                        Position = target
                    }):Play()
                end
            end
        end

